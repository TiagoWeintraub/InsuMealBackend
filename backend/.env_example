# FastApi server port 
export PORT = 8000

# Database configuration
export DATABASE_URL=postgresql://postgres:'contraseña'@localhost/insumeal
export DATABASE_NAME = insumeal.db

# Gemini Api (modelo por defecto: gemini-2.5-flash-lite si no se define)
export GEMINI_API_KEY = 'api_key'
export GEMINI_MODEL = 'gemini-2.5-flash-lite'

# Edamam Api
export EDAMAM_APP_ID = 'api_id'
export EDAMAM_APP_KEY = 'api_key'
export EDAMAM_URL = 'https://api.edamam.com/api/food-database/v2'

# USDA Api
export USDA_API_KEY = 'api_key'
export USDA_URL = 'https://api.nal.usda.gov/fdc/v1/foods/search/?'

# JWT Secret Key
export SECRET_KEY = "contraseña"
export ALGORITHM = "HS256"
export ACCESS_TOKEN_EXPIRE_MINUTES = 1440 # Por ej: 24 hours . 60 minutes
